# Prompt Wars Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# MOBILE PUBLIC VARIABLES (safe to bundle in the app)
# ============================================================

# Supabase - Public client keys
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat - Public API keys (per platform)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-ios-key-here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-android-key-here

# Deep link scheme for auth redirects (matches app.config.js scheme)
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=com.promptwars.promptwars

# App URL for web deep links (production)
EXPO_PUBLIC_APP_URL=https://promptwars.app

# App Configuration
APP_VARIANT=development

# ============================================================
# BACKEND/EDGE FUNCTION SECRET VARIABLES
# (DO NOT add to mobile .env; managed by backend executor)
# These are documented here for reference only.
# Configure them in Supabase Edge Function secrets.
# ============================================================

# Supabase - Service role key (server-side only)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LLM Judge Provider (server-side only)
# JUDGE_PROVIDER=openai
# JUDGE_API_KEY=sk-...
# JUDGE_MODEL_ID=gpt-4-turbo-preview
# JUDGE_PROMPT_VERSION=v1

# Video Generation Provider (server-side only)
# XAI_API_KEY=xai-...
# XAI_VIDEO_MODEL=grok-video-v1
# XAI_VIDEO_TIMEOUT_MS=300000

# Image Generation Provider for Tier 0 (server-side only)
# IMAGE_PROVIDER=replicate
# IMAGE_API_KEY=r8_...
# IMAGE_MODEL_ID=stability-ai/sdxl

# Moderation Providers (server-side only)
# TEXT_MODERATION_PROVIDER=openai
# TEXT_MODERATION_API_KEY=sk-...
# VIDEO_MODERATION_PROVIDER=hivemoderation
# VIDEO_MODERATION_API_KEY=your-hive-api-key

# RevenueCat Server-Side (server-side only)
# REVENUECAT_WEBHOOK_SECRET=sk_...
# REVENUECAT_API_KEY=sk_...

# Push Notifications (server-side only)
# EXPO_PUSH_TOKEN=your-expo-push-token

# ============================================================
# NOTES
# ============================================================
# - Mobile app ONLY uses EXPO_PUBLIC_* variables
# - Service role keys, provider keys, and webhook secrets MUST
#   be configured in Supabase Edge Function secrets, NOT here
# - Backend executor owns supabase/ folder and Edge Function config
# - See docs/prompt-wars-implementation-concept.md for full architecture
